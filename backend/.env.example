NODE_ENV=development
PORT=3333

# Local development
FRONTEND_URL=http://localhost:5173

# Production can use multiple origins separated by comma.
# Example:
# FRONTEND_URLS=https://amigo-secreto.pages.dev,https://www.seu-dominio.com
FRONTEND_URLS=http://localhost:5173

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/amigo_secreto?schema=public"

# Production email provider. Prefer Resend on Render Free because common SMTP
# ports are blocked there.
MAIL_PROVIDER=smtp
RESEND_API_KEY=
MAIL_FROM="Amigo Secreto <no-reply@seu-dominio.com>"
MAIL_REPLY_TO="Amigo Secreto <no-reply@seu-dominio.com>"

# SMTP fallback for local development/testing, for example Ethereal.
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Amigo Secreto <no-reply@amigosecreto.local>"
SMTP_REPLY_TO="Amigo Secreto <no-reply@amigosecreto.local>"
